# BitLink Production Caddyfile
# Requires DOMAIN env var (e.g. DOMAIN=bitlink.example.com)

# API — reverse proxy with WebSocket support
api.{$DOMAIN} {
	reverse_proxy api:8000
}

# Frontend — static SPA served from built dist
app.{$DOMAIN} {
	root * /srv/ui
	file_server
	try_files {path} /index.html

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
	}
}

# Media — proxy to MinIO for public assets
media.{$DOMAIN} {
	reverse_proxy minio:9000

	header {
		Access-Control-Allow-Origin *
		Access-Control-Allow-Methods "GET, HEAD, OPTIONS"
		Cache-Control "public, max-age=31536000, immutable"
	}
}
