# =============================================================================
# BitLink Production Environment
# =============================================================================
# Copy to .env.prod and fill in real values. NEVER commit .env.prod to git.
# =============================================================================

# Domain (used by Caddy and VITE_API_URL)
DOMAIN=bitlink.example.com

# Database
DB_USER=bitlink
DB_PASSWORD=CHANGE_ME_strong_random_password
DB_NAME=bitlink

# Redis
REDIS_PASSWORD=CHANGE_ME_redis_password

# Auth
SECRET_KEY=CHANGE_ME_openssl_rand_base64_32

# S3 / MinIO
S3_ACCESS_KEY=CHANGE_ME_minio_access
S3_SECRET_KEY=CHANGE_ME_minio_secret

# TRON Blockchain
TRON_NETWORK=shasta
TRON_XPUB=
TRON_API_KEY=

# Binance CEX (optional)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true
