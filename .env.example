# ============================================================================
# BitLink Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# After the compliance pivot BitLink is a non-custodial tipping app:
#   - Wallets:    Privy embedded wallet (key shares + TEE)
#   - Token:      USDC on Base (chain id 8453)
#   - Server:     auth + activity log only; never holds user funds
# See CLAUDE.md for the full architecture.
# ============================================================================

# ----------------------------------------
# Database
# ----------------------------------------
DATABASE_URL=postgresql://bitlink:bitlink@localhost:5432/bitlink
# For Docker Compose internal networking:
# DATABASE_URL=postgresql://bitlink:bitlink@postgres:5432/bitlink

# ----------------------------------------
# Redis
# ----------------------------------------
REDIS_URL=redis://localhost:6379
# For Docker Compose internal networking:
# REDIS_URL=redis://redis:6379

# ----------------------------------------
# Authentication
# ----------------------------------------
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this

# Privy (https://dashboard.privy.io)
PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret
PRIVY_JWKS_URL=https://auth.privy.io/api/v1/apps/your-privy-app-id/jwks.json

# Google OAuth (legacy dev path; only used if Privy is unconfigured)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ----------------------------------------
# Base chain (USDC tipping)
# ----------------------------------------
BASE_RPC_URL=https://mainnet.base.org
BASE_CHAIN_ID=8453
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
USDC_DECIMALS=6

# Tip economics (in micro-USDC, 1_000_000 = $1)
MIN_TIP_MICRO=10000
DEFAULT_TIP_MICRO=100000
MAX_TIP_MICRO=10000000
TIP_CONFIRMATION_BLOCKS=2

# Free posts per day (non-monetary anti-spam quota)
FREE_POSTS_PER_DAY=10

# ----------------------------------------
# AI Services
# ----------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx
OPENAI_API_KEY=sk-xxxxx
GROQ_API_KEY=gsk_xxxxx

# ----------------------------------------
# Service URLs (local dev)
# ----------------------------------------
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ----------------------------------------
# Rate Limiting
# ----------------------------------------
RATE_LIMIT_RPM=60
POST_LIMIT_HOURLY=20

# ----------------------------------------
# Logging
# ----------------------------------------
LOG_LEVEL=debug
LOG_FORMAT=pretty

# ----------------------------------------
# Node Environment
# ----------------------------------------
NODE_ENV=development
