# Pay Service Configuration

# Database
DATABASE_URL=postgresql+asyncpg://bitlink:bitlink_dev_password@localhost:5435/bitlink

# Redis
REDIS_URL=redis://localhost:6380/1

# TRON Configuration
TRON_NETWORK=shasta  # mainnet, shasta (testnet), nile (testnet)
TRON_XPUB=  # Extended public key from test_shasta.py
TRON_API_KEY=  # Optional TronGrid API key for higher rate limits

# Deposit Monitoring
DEPOSIT_POLL_INTERVAL=10  # seconds
DEPOSIT_CONFIRMATIONS=20  # blocks to wait

# Hot wallet for automated withdrawals (TESTING ONLY - use cold signing in production)
HOT_WALLET_PRIVATE_KEY=
HOT_WALLET_MAX_WITHDRAWAL=100000000  # 100 USDT in smallest unit

# Service
ENV=development
DEBUG=true
