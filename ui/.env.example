# BitLink frontend environment variables
# Copy to ui/.env (which is git-ignored) and fill in.

# === Backend ===
VITE_API_URL=http://localhost:8003

# === Privy (https://dashboard.privy.io) ===
# Create a free Privy app, then set its App ID here.
# Allowed origins in Privy dashboard:
#   http://localhost:3003
#   https://bitlink.app
#   capacitor://localhost
#   https://localhost
VITE_PRIVY_APP_ID=

# === Base mainnet RPC ===
# Free tier from Alchemy works (300M req/mo). Or use https://mainnet.base.org (rate-limited public).
VITE_BASE_RPC_URL=https://mainnet.base.org

# === Onchain addresses (Base mainnet) ===
# USDC on Base: https://basescan.org/token/0x833589fcd6edb6e08f4c7c32d4f71b54bda02913
VITE_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# === Default tip amount (USDC, 6 decimals) ===
# 100000 = $0.10. Slider in app ranges $0.01–$100 (10000–100000000).
VITE_DEFAULT_TIP_MICRO=100000

# === Dev-only ===
# Set to "true" to show the Quick Login (dev user picker) on the LoginPage.
VITE_DEV_QUICK_LOGIN=false
